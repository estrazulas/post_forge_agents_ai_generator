OPENROUTER_API_KEY=
# Use openrouter/free para roteamento automatico gratuito,
# ou um modelo especifico com sufixo :free.
OPENROUTER_MODEL=openrouter/free
TEXT_RETRIES=2
TEXT_TIMEOUT_MS=15000
GENERATION_VARIANTS=1

# Backend de imagem: remote (real) ou mock (teste sem chamada externa)
IMAGE_BACKEND=remote
IMAGE_PROVIDER_BASE_URL=https://api.openai.com/v1

# Caminhos usados quando rodando via docker compose
IMAGE_PROFILES_CATALOG_PATH=/app/config/image-profiles.catalog.example.json
IMAGE_DEFAULT_PROFILE=balanced
HERO_REFERENCES_DIR=/workspace/assets/hero-references

# Credencial para modelos de imagem da OpenAI
OPENAI_API_KEY=
